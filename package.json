{
  "name": "mastering-studio-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "cf:dev": "wrangler pages dev dist --d1 DB",
    "cf:build": "vite build",
    "cf:deploy": "npm run cf:build && wrangler pages deploy dist",
    "cf:migrate": "wrangler d1 migrations apply mastering-studio-db",
    "clean": "node -e \"require('fs').rmSync('dist',{force:true,recursive:true});require('fs').rmSync('mastering.db',{force:true,recursive:true})\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "wavesurfer.js": "^7.12.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.105.0"
  }
}
