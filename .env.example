# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT secret for authentication tokens
JWT_SECRET="mastering_studio_ai_super_secret_token_123!@#"

# Encryption key for storing API keys in SQLite (local dev only)
ENCRYPTION_KEY="mastering_studio_ai_enc_key_32_bytes_long_!!!"

# APP_URL: The URL where the app is hosted
APP_URL="http://localhost:3000"

# ==========================================
# Cloudflare D1 — used in production (Pages Functions)
# Database is configured via wrangler.toml binding
# ==========================================
# No local env vars needed for D1; it's bound at runtime
